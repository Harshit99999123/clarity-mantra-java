DB_URL=jdbc:mysql://localhost:3306/clarity_mantra?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=change-me
DB_POOL_NAME=clarity-hikari
DB_MAX_POOL_SIZE=20
DB_MIN_IDLE=5
DB_IDLE_TIMEOUT_MILLIS=600000
DB_MAX_LIFETIME_MILLIS=1800000
DB_KEEPALIVE_TIME_MILLIS=300000
DB_CONNECTION_TIMEOUT_MILLIS=30000
DB_VALIDATION_TIMEOUT_MILLIS=5000
DB_INITIALIZATION_FAIL_TIMEOUT_MILLIS=1
DB_TRANSACTION_TIMEOUT=30s
JPA_DDL_AUTO=update

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION_MINUTES=1440

GOOGLE_CLIENT_IDS=your-google-client-id.apps.googleusercontent.com

AI_SERVICE_BASE_URL=http://127.0.0.1:8000
AI_CONNECT_TIMEOUT_SECONDS=5
AI_READ_TIMEOUT_SECONDS=90

AI_MAX_ATTEMPTS=3
AI_INITIAL_BACKOFF_MILLIS=250
AI_MAX_BACKOFF_MILLIS=2000
AI_JITTER_FACTOR=0.35
AI_CIRCUIT_FAILURE_THRESHOLD=5
AI_CIRCUIT_OPEN_MILLIS=30000

SERVER_TOMCAT_MAX_THREADS=200
SERVER_TOMCAT_MIN_SPARE_THREADS=20
SERVER_TOMCAT_ACCEPT_COUNT=100
SERVER_TOMCAT_CONNECTION_TIMEOUT_MILLIS=5000
APP_SHUTDOWN_TIMEOUT=30s
